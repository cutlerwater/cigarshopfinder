generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  city        String
  state       String
  stateabb    String
  zip         String
  address     String
  phone       String
  website     String?
  description String
  image       String?
  hasLounge   Boolean @default(false)
  hasHumidor  Boolean @default(false)
  heroVideo  String?
  heroPoster String?

  hasPadron       Boolean @default(false)
  hasFuente       Boolean @default(false)
  hasOpusX        Boolean @default(false)
  hasRareOpusX    Boolean @default(false)
  hasAshton       Boolean @default(false)
  hasDiamond      Boolean @default(false)
  hasAroma        Boolean @default(false)
  hasDavidoff     Boolean @default(false)
  hasAvo          Boolean @default(false)
  hasLiga         Boolean @default(false)
  hasAcid         Boolean @default(false)
  hasTatuaje      Boolean @default(false)
  hasPerdomo      Boolean @default(false)
  hasAlec         Boolean @default(false)
  hasHoya         Boolean @default(false)
  hasLFD          Boolean @default(false)
  hasOliva        Boolean @default(false)
  hasNub          Boolean @default(false)
  hasCain         Boolean @default(false)
  hasMyFather     Boolean @default(false)
  hasCamacho      Boolean @default(false)
  hasAJ           Boolean @default(false)
  hasSanCristobal Boolean @default(false)
  hasAtabey       Boolean @default(false)
  hasLordByron    Boolean @default(false)
  hasGreyCliff    Boolean @default(false)
  hasDunhill      Boolean @default(false)
  hasHouseCigar   Boolean @default(false)
  hasMontecristo  Boolean @default(false)
  hasRomeo        Boolean @default(false)
  hasHuppman      Boolean @default(false)
  hasCAO          Boolean @default(false)
  hasRP           Boolean @default(false)
  hasCohiba       Boolean @default(false)
  hasPunch        Boolean @default(false)
  hasAging        Boolean @default(false)
  hasMacanudo     Boolean @default(false)
  hasGurkha       Boolean @default(false)
  hasPartagas     Boolean @default(false)
  hasLaAurora     Boolean @default(false)
  hasPlasencia    Boolean @default(false)
  hasAganorsa     Boolean @default(false)

  hasMemberLocker   Boolean  @default(false)
  sellsFood         Boolean  @default(false)
  sellsDrink        Boolean  @default(false)
  hasPipeTobacco    Boolean  @default(false)
  hasMemberAccess   Boolean  @default(false)
  hasHooka          Boolean  @default(false)
  hasEvents         Boolean  @default(false)
  hasLiveMusic      Boolean  @default(false)
  hasLiquorLicense  Boolean  @default(false)
  canBringInLiquor  Boolean  @default(false)
  hasInternetAccess Boolean  @default(false)
  hasCoffeeMaker    Boolean  @default(false)
  hasIceMaker       Boolean  @default(false)
  hasBigTV          Boolean  @default(false)
  sellsAccessory    Boolean  @default(false)
  latitude          Float?
  longitude         Float?
  isFeatured        Boolean  @default(false)
  isSponsored       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reviews Review[]
}

model ShopSubmission {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  state       String
  stateabb    String
  zip         String?
  phone       String?
  website     String?
  description String?

  hasLounge        Boolean @default(false)
  hasHumidor       Boolean @default(false)
  sellsAccessories Boolean @default(false)
  canBringInLiquor Boolean @default(false)
  hasEvents        Boolean @default(false)

  contactName  String?
  contactEmail String

  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  body       String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  reviews       Review[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
