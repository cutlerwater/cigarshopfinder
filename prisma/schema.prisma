generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  city              String
  state             String
  stateabb          String
  zip               String
  address           String
  phone             String
  website           String?
  description       String
  image             String?
  hasLounge         Boolean  @default(false)
  hasHumidor        Boolean  @default(false)
  hasDavidoffs      Boolean @default(false)
  hasPadrons        Boolean @default(false)
  hasOpusX          Boolean @default(false)
  hasAcid           Boolean @default(false)
  hasPipeTobacco    Boolean @default(false)
  hasMemberAccess   Boolean @default(false)
  hasHooka          Boolean @default(false)
  hasEvents         Boolean @default(false)
  hasLiquorLicense  Boolean @default(false)
  canBringInLiquor  Boolean @default(false)
  hasInternetAccess Boolean @default(false)
  hasCoffeeMaker    Boolean @default(false)
  hasIceMaker       Boolean @default(false)
  hasBigTV          Boolean @default(false)
  sellsAccessories  Boolean  @default(false)
  latitude          Float?
  longitude         Float?
  isFeatured        Boolean  @default(false)
  isSponsored       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reviews Review[]
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  title      String?
  body       String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}
